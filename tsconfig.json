{
  "compilerOptions": {
    "target": "ES2017",
    "module": "ESNext",
    "declaration": true,
    "outDir": "lib",
    "strict": true,
    "lib": ["ESNext", "DOM", "ES2015"],
    "jsx": "react-jsx",
    "allowSyntheticDefaultImports": true,
    "moduleResolution": "bundler",
    "baseUrl": "./src"
  },
  "include": ["src"],
  "exclude": ["node_modules", "lib"]
}
